# ============================================
# UseMe AI - Environment Variables
# Copy this file to server/.env and fill in your real values
# ============================================

# Groq API key -> get free key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Neon Postgres connection string
# Get from https://console.neon.tech -> your project -> Connection Details
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=your_neon_connection_string_here

# Secret used to sign login session tokens (any long random string)
JWT_SECRET=change_this_to_a_long_random_string

# Port the backend server runs on
PORT=5000
